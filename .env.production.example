# Production deploy — copy thành .env.production hoặc set trên Vercel/Netlify khi build
# npm run build tự load (mode production)

VITE_API_BASE_URL=https://api.cosmate.site
VITE_APP_BASE_URL=https://cosmate.site

# --- GHN shipping (ước tính phí) — prod BẮT BUỘC có VITE_GHN_API_BASE ---
# Cách 1: reverse proxy /ghn-proxy → https://online-gateway.ghn.vn (khuyến nghị)
#   location /ghn-proxy/ { proxy_pass https://online-gateway.ghn.vn/; ... }
# VITE_GHN_API_BASE=/ghn-proxy
# Cách 2: URL gateway trực tiếp (có thể gặp CORS từ browser)
# VITE_GHN_API_BASE=https://online-gateway.ghn.vn
VITE_GHN_TOKEN=
VITE_GHN_SHOP_ID=
VITE_GHN_DEFAULT_WEIGHT_GRAM=1000
VITE_GHN_DEFAULT_LENGTH_CM=30
VITE_GHN_DEFAULT_WIDTH_CM=30
VITE_GHN_DEFAULT_HEIGHT_CM=10
