# =============================================================================
# CosMate — Docker Compose (copy thành .env ở THƯ MỤC GỐC bộ nộp, cạnh docker-compose.yml)
# =============================================================================

# --- Cổng ---
WEB_PORT=80
API_PORT=8080

# --- SQL Server (database CosMate phải đã restore / migrate sẵn) ---
# Windows + Docker Desktop: host.docker.internal
# Linux: có thể cần IP máy host thay host.docker.internal
SPRING_DATASOURCE_URL=jdbc:sqlserver://host.docker.internal:1433;encrypt=true;trustServerCertificate=true;databaseName=CosMate
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=YourStrongPassword123!

SPRING_PROFILES_ACTIVE=prod

# --- JWT (bắt buộc — chuỗi dài, random) ---
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# --- URL cho redirect thanh toán / CORS ---
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost:8080
SPRING_WEB_CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# --- Google OAuth (tuỳ chọn — đăng nhập Google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI Gemini (tuỳ chọn — Pose Battle, quiz, mô tả AI) ---
GEMINI_API_KEY=

# --- Email (tuỳ chọn — quên mật khẩu) ---
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# --- MoMo / VNPay sandbox (tuỳ chọn) ---
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
VNP_TMN_CODE=
VNP_HASH_SECRET=

# --- GHN server-side (tuỳ chọn — ship đơn) ---
GHN_TOKEN=
GHN_SHOP_ID=

# --- Firebase (tuỳ chọn) ---
FIREBASE_SERVICE_ACCOUNT_FILE=cosmate-firebase.json
FIREBASE_BUCKET_NAME=

# =============================================================================
# Frontend (VITE_*) — chỉ dùng khi BUILD dist, không đọc lúc runtime Docker
# Ghi vào .env.production trước: npm run build
# =============================================================================
# VITE_API_BASE_URL=http://localhost:8080
# VITE_APP_BASE_URL=http://localhost
# VITE_GOOGLE_CLIENT_ID=
# VITE_GHN_API_BASE=
# VITE_GHN_TOKEN=
# VITE_GHN_SHOP_ID=
