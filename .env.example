# CosMate Frontend Environment Variables
# Copy this file to .env and update with your actual values

# API Base URL
# Development: http://localhost:8080
# Staging: https://staging-api.cosmate.com
# Production: https://api.cosmate.com
VITE_API_BASE_URL=http://localhost:8080

# App Configuration
VITE_APP_NAME=CosMate
VITE_APP_VERSION=1.0.0
VITE_GOOGLE_CLIENT_ID=877779648983-9e8u32cam08nv3lfhob09cnl9sbg4pmi.apps.googleusercontent.com
# Google OAuth (Optional)
# Get your client ID from https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Web application type)
# Add http://localhost:5173 to Authorized JavaScript origins
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional: Analytics, Monitoring, etc.
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_SENTRY_DSN=
