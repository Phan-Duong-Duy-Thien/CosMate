# =============================================================================
# CosMate FE — template biến môi trường (copy sang .env.development / .env.production)
# Vite chỉ expose biến bắt đầu VITE_. Sau khi đổi phải restart dev hoặc build lại.
# =============================================================================

# --- CosMate API (BE) — axios + returnUrl callback MoMo/VNPay (không slash cuối) ---
# Swagger: https://api.cosmate.site/swagger-ui/index.html
VITE_API_BASE_URL=https://api.cosmate.site

# --- CosMate Web (FE) — origin deploy; BE redirect user về đây sau thanh toán ---
# Dev: http://localhost:5173 | Prod: URL deploy thật (không slash cuối)
# FE origin: prod https://cosmate.site | dev local http://localhost:5173
VITE_APP_BASE_URL=https://cosmate.site

# --- Mobile QR (tuỳ chọn; mặc định = VITE_API_BASE_URL) ---
# VITE_MOBILE_API_BASE_URL=

# --- Google Sign-In ---
VITE_GOOGLE_CLIENT_ID=

# --- GHN shipping (ước tính phí vận chuyển) ---
# Master-data tỉnh/quận/phường: npm run ghn:sync-master → public/data/ghn-master.json (commit file)
# Dev: bật dòng dưới — Vite proxy /ghn-proxy → online-gateway.ghn.vn (xem vite.config.ts)
VITE_GHN_API_BASE=/ghn-proxy
# Prod: BẮT BUỘC set VITE_GHN_API_BASE (vd. /ghn-proxy nếu nginx proxy, hoặc URL gateway đầy đủ)
VITE_GHN_TOKEN=
VITE_GHN_SHOP_ID=6307226
VITE_GHN_DEFAULT_WEIGHT_GRAM=1000
VITE_GHN_DEFAULT_LENGTH_CM=30
VITE_GHN_DEFAULT_WIDTH_CM=30
VITE_GHN_DEFAULT_HEIGHT_CM=10

# --- GeoVina — chuẩn hóa địa chỉ (dev: proxy /geovina-proxy) ---
VITE_GEOVINA_API_BASE=/geovina-proxy
VITE_GEOVINA_API_KEY=
